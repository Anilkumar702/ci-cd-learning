{
  "name": "ci-cd-learning",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run test",
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.0.2",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/react": "^18.2.57",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  },
  "vitest": {
    "test": {
      "environment": "jsdom",
      "globals": true,
      "setupFiles": "./src/setupTests.js",
      "include": [
        "src/**/*.{test,spec}.{js,jsx}"
      ]
    }
  }
}
